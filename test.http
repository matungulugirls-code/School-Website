Content-Type: application/json

{
  "jobTitle": "Mathematics Teacher",
  "department": "Mathematics Department",
  "category": "teaching",
  "jobType": "full-time",
  "positionsAvailable": 2,
  "jobDescription": "We are seeking an experienced and passionate Mathematics Teacher to join our academic team. The ideal candidate will have a strong background in teaching Mathematics at the secondary school level, with expertise in both theoretical concepts and practical applications. You will be responsible for preparing students for KCSE examinations and developing innovative teaching methods.",
  "experience": "3+ years teaching experience",
  "qualifications": "Bachelor of Education (Mathematics) with TSC registration. Master's degree preferred.",
  "requirements": "TSC registered, excellent communication skills, ability to use modern teaching aids, proven track record of improving student performance in Mathematics.",
  "applicationDeadline": "2026-03-15",
  "contactEmail": "matungulugirls@gmail.com",
  "contactPhone": "+254712345678",
  "location": "Matungulu, Machakos County"
}

