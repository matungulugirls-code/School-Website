generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(cuid())
  name           String
  email          String          @unique
  emailVerified  DateTime?
  password       String?
  phone          String?
  role           UserRole        @default(ADMIN)
  image          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  passwordResets PasswordReset[]

  // Add these relations to fix the error
  loginAttempts LoginAttempt[]
  deviceTokens  DeviceToken[]

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  createdAt DateTime @default(now())
  expires   DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "PasswordReset_userId_fkey")
}

model LoginAttempt {
  id          String   @id @default(cuid())
  userId      String?
  email       String
  ipAddress   String?
  userAgent   String?
  deviceHash  String? // Browser fingerprint hash
  status      String // "success", "failed", "blocked"
  reason      String? // "wrong_password", "verification_required"
  attemptedAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([attemptedAt])
  @@map("login_attempts")
}

model DeviceToken {
  id            String    @id @default(cuid())
  userId        String
  deviceHash    String
  deviceName    String?
  lastUsed      DateTime  @default(now())
  expiresAt     DateTime
  isTrusted     Boolean   @default(false)
  isBlocked     Boolean   @default(false)
  loginCount    Int       @default(1)
  countsResetAt DateTime? // NEW: When counts were last reset
  isCountsReset Boolean   @default(false) // NEW: Flag indicating counts were reset
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceHash])
  @@index([userId])
  @@index([deviceHash])
  @@index([expiresAt])
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())

  @@map("subscribers")
}

model Assignment {
  id                 Int      @id @default(autoincrement())
  title              String
  subject            String
  className          String
  teacher            String
  dueDate            DateTime
  dateAssigned       DateTime
  status             String
  description        String   @db.Text
  instructions       String?  @db.Text
  assignmentFiles    Json
  attachments        Json
  priority           String
  estimatedTime      String?
  additionalWork     String?  @db.Text
  teacherRemarks     String?  @db.Text
  feedback           String?  @db.Text
  learningObjectives Json
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Resource {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(400)
  subject     String   @db.VarChar(100)
  teacher     String   @db.VarChar(100)
  className   String   @db.VarChar(50)
  description String?  @db.Text
  category    String   @default("general") @db.VarChar(100)
  type        String   @default("document") @db.VarChar(50)
  files       Json // Array of file objects (like assignmentFiles)
  accessLevel String   @default("student") @db.VarChar(20)
  uploadedBy  String   @default("System") @db.VarChar(100)
  downloads   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([subject])
  @@index([className])
  @@index([category])
  @@index([type])
  @@index([accessLevel])
  @@index([createdAt])
  @@map("resources")
}

model CounselingEvent {
  id          Int      @id @default(autoincrement())
  counselor   String
  category    String
  description String   @db.Text
  notes       String?  @db.Text
  date        DateTime
  time        String
  type        String
  priority    String
  image       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Event {
  id            Int      @id @default(autoincrement())
  title         String
  description   String?  @db.Text
  date          DateTime
  time          String
  location      String
  category      String
  type          String
  featured      Boolean  @default(false)
  registration  Boolean  @default(false)
  attendees     String
  speaker       String
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  createdBy     String?
  updatedBy     String?
  updatedByName String?
  updatedByRole String?
}

model News {
  id            Int      @id @default(autoincrement())
  title         String
  excerpt       String?  @db.Text
  fullContent   String?  @db.Text
  date          DateTime
  category      String
  isFeatured    Boolean  @default(false)
  author        String
  likes         Int      @default(0)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  createdBy     String?
  updatedBy     String?
  updatedByName String?
  updatedByRole String?
}

model Staff {
  id               Int      @id @default(autoincrement())
  name             String
  role             String
  staffType        String?  @default("Leadership") @db.VarChar(50)
  position         String?
  department       String?
  departmentId     Int?
  departmentRecord StaffDepartment? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  subjectOffered   String?  @db.VarChar(255)
  education        String?  @db.Text
  experience       String?  @db.Text
  email            String?
  phone            String?
  bio              String?  @db.Text
  quote            String?  @db.Text
  gender           String?  @default("male") // ← ADD THIS
  status           String?  @default("active") // ← ADD THIS
  joinDate         String? // ← ADD THIS
  responsibilities Json?
  expertise        Json?
  achievements     Json?
  image            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([departmentId])
}

// ==========================================
// Staff Departments (public grouping only)
// ==========================================

enum DepartmentCategory {
  CBC
  EIGHT_FOUR_FOUR
  TEACHING
  SUPPORT
}

model StaffDepartment {
  id           Int                    @id @default(autoincrement())
  name         String                 @db.VarChar(255)
  category     DepartmentCategory
  description  String?                @db.Text
  image        String?                @db.Text
  images       StaffDepartmentImage[]
  staffCount   Int                    @default(0)
  headName     String?                @db.VarChar(255)
  assistantHeadName String?           @db.VarChar(255)
  extra        Json?
  isActive     Boolean                @default(true)
  displayOrder Int                    @default(0)
  teachers     Staff[]
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  @@index([category])
  @@index([isActive])
  @@index([displayOrder])
  @@map("staff_departments")
}

model StaffDepartmentImage {
  id                Int             @id @default(autoincrement())
  staffDepartmentId Int
  url               String          @db.Text
  publicId          String?         @db.Text
  caption           String?         @db.VarChar(255)
  altText           String?         @db.VarChar(255)
  displayOrder      Int             @default(0)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  staffDepartment   StaffDepartment @relation(fields: [staffDepartmentId], references: [id], onDelete: Cascade)

  @@index([staffDepartmentId])
  @@index([displayOrder])
  @@map("staff_department_images")
}

// ==========================================
// School Hub Items (Clubs, Societies, etc.)
// ==========================================

enum SchoolHubType {
  CLUB
  SOCIETY
  STUDENT_COUNCIL
  COMPUTER_LAB
  FARM
  BOARDING
  SECURITY
  DEPARTMENT
}

model SchoolHubItem {
  id               Int              @id @default(autoincrement())
  type             SchoolHubType
  title            String           @db.VarChar(255)
  shortDescription String?          @db.Text
  description      String?          @db.Text
  image            String?          @db.Text
  images           SchoolHubImage[]
  location         String?          @db.VarChar(255)
  established      String?          @db.VarChar(100)
  website          String?          @db.VarChar(255)
  socialMedia      Json             @default("{}")
  contactName      String?          @db.VarChar(255)
  contactPhone     String?          @db.VarChar(50)
  contactEmail     String?          @db.VarChar(255)
  details          Json             @default("[]")
  isActive         Boolean          @default(true)
  displayOrder     Int              @default(0)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([type])
  @@index([isActive])
  @@index([displayOrder])
  @@map("school_hub_items")
}

model SchoolHubImage {
  id              Int           @id @default(autoincrement())
  schoolHubItemId Int
  url             String        @db.Text
  publicId        String?       @db.Text
  caption         String?       @db.VarChar(255)
  altText         String?       @db.VarChar(255)
  displayOrder    Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  schoolHubItem   SchoolHubItem @relation(fields: [schoolHubItemId], references: [id], onDelete: Cascade)

  @@index([schoolHubItemId])
  @@index([displayOrder])
  @@map("school_hub_images")
}

model EmailCampaign {
  id            String    @id @default(cuid())
  title         String
  subject       String
  content       String    @db.Text
  recipients    String    @db.Text
  recipientType String    @default("all")
  status        String    @default("draft")
  sentAt        DateTime?
  sentCount     Int?
  failedCount   Int?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  attachments   String?   @db.Text

  @@map("email_campaigns")
}

model SmsCampaign {
  id             String    @id @default(cuid())
  title          String
  message        String
  recipients     String // Comma-separated phone numbers
  recipientType  String?   @default("all")
  status         String    @default("draft") // "draft" or "sent"
  sentAt         DateTime?
  sentCount      Int?      @default(0)
  failedCount    Int?      @default(0)
  lowCreditSaved Boolean   @default(false) // Add this line
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  logs SmsLog[]

  @@map("sms_campaigns")
}

model SmsLog {
  id                String   @id @default(cuid())
  campaignId        String
  userId            String? // optional, if you track users
  phoneNumber       String // <-- Make sure this is String, not Int
  message           String   @db.Text
  providerMessageId String? // Africa's Talking messageId
  status            String // success, failed
  errorMessage      String?
  timestamp         DateTime @default(now())

  campaign SmsCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("sms_logs")
}

model GalleryImage {
  id          Int      @id @default(autoincrement())
  title       String
  description String?  @db.Text
  category    Category
  files       Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Magazine {
  id          Int      @id @default(autoincrement())
  title       String
  year        Int
  description String?  @db.Text
  pdfUrl      String
  thumbnail   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relation defined here (One-to-One)
  schoolInfo   SchoolInfo? @relation(fields: [schoolInfoId], references: [id])
  schoolInfoId Int?        @unique
}

model SchoolInfo {
  id           Int      @id @default(autoincrement())
  // REMOVE magazineId and magazine from here - they're not needed
  name         String   @db.VarChar(255)
  description  String?  @db.Text
  motto        String?  @db.Text
  vision       String?  @db.Text
  mission      String?  @db.Text
  studentCount Int      @default(0)
  staffCount   Int      @default(0)
  openDate     DateTime
  closeDate    DateTime

  subjects    Json @default("[]")
  departments Json @default("[]")

  videoTour      String? @db.Text
  videoType      String? @db.VarChar(20)
  videoThumbnail String? @db.Text

  feesDay      Float?
  feesBoarding Float?
  admissionFee Float?

  admissionOpenDate          DateTime?
  admissionCloseDate         DateTime?
  admissionRequirements      String?   @db.Text
  admissionCapacity          Int?
  admissionContactEmail      String?   @db.VarChar(255)
  admissionContactPhone      String?   @db.VarChar(50)
  admissionWebsite           String?   @db.VarChar(255)
  admissionLocation          String?   @db.Text
  admissionOfficeHours       String?   @db.Text
  admissionDocumentsRequired Json      @default("[]")
  form1ResultsTerm           String?   @db.VarChar(50)
  form2ResultsTerm           String?   @db.VarChar(50)
  form3ResultsTerm           String?   @db.VarChar(50)
  form4ResultsTerm           String?   @db.VarChar(50)
  mockExamsTerm              String?   @db.VarChar(50)
  kcseTerm                   String?   @db.VarChar(50)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  Magazine  Magazine?

  @@index([name])
  @@index([admissionOpenDate, admissionCloseDate])
  @@map("SchoolInfo")
}

// Individual Achievement Model
model Achievement {
  id          Int     @id @default(autoincrement())
  title       String  @db.VarChar(255)
  description String? @db.Text
  category    String  @db.VarChar(100) // e.g., "Academic", "Sports", "Arts", "Leadership"
  year        Int // Year the achievement was earned

  // Images stored as JSON array
  images Json @default("[]") // Array of { url, public_id, caption }

  // Display options
  featured     Boolean @default(false)
  displayOrder Int     @default(0)
  isActive     Boolean @default(true)

  // Additional metadata
  awardingBody String? @db.VarChar(255)
  recipients   Json    @default("[]") // Array of recipient names

  // Timestamps
  achievedDate DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([category])
  @@index([year])
  @@index([featured])
  @@index([isActive])
  @@map("Achievement")
}

// School Stats Model (for constant mean and target values)
model SchoolStats {
  id Int @id @default(autoincrement())

  meanScore    Float? // Overall mean score
  lastYearMean Float? // Last year's mean score
  targetMean   Float? // Target mean for current year

  // School slogan
  slogan            String? @db.Text
  sloganDescription String? @db.Text
  sloganAuthor      String? @db.VarChar(255)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("SchoolStats")
}

model SchoolDocument {
  id Int @id @default(autoincrement())

  // Curriculum PDF
  curriculumPDF           String?   @db.Text
  curriculumPdfName       String?   @db.VarChar(255)
  curriculumPdfSize       Int?
  curriculumPdfUploadDate DateTime?
  curriculumDescription   String?   @db.Text
  curriculumYear          Int?
  curriculumTerm          String?   @db.VarChar(50)

  // Day School Fees PDF
  feesDayDistributionPdf String?   @db.Text
  feesDayPdfName         String?   @db.VarChar(255)
  feesDayPdfSize         Int?
  feesDayPdfUploadDate   DateTime?
  feesDayDescription     String?   @db.Text
  feesDayYear            Int?
  feesDayTerm            String?   @db.VarChar(50)

  // Boarding School Fees PDF
  feesBoardingDistributionPdf String?   @db.Text
  feesBoardingPdfName         String?   @db.VarChar(255)
  feesBoardingPdfSize         Int?
  feesBoardingPdfUploadDate   DateTime?
  feesBoardingDescription     String?   @db.Text
  feesBoardingYear            Int?
  feesBoardingTerm            String?   @db.VarChar(50)

  // Admission Fee PDF
  admissionFeePdf           String?   @db.Text
  admissionFeePdfName       String?   @db.VarChar(255)
  admissionFeePdfSize       Int?
  admissionFeePdfUploadDate DateTime?
  admissionFeeDescription   String?   @db.Text
  admissionFeeYear          Int?
  admissionFeeTerm          String?   @db.VarChar(50)

  // Form 1 Results PDF
  form1ResultsPdf         String?   @db.Text
  form1ResultsPdfName     String?   @db.VarChar(255)
  form1ResultsPdfSize     Int?
  form1ResultsDescription String?   @db.Text
  form1ResultsYear        Int?
  form1ResultsTerm        String?   @db.VarChar(50)
  form1ResultsUploadDate  DateTime?

  // Form 2 Results PDF
  form2ResultsPdf         String?   @db.Text
  form2ResultsPdfName     String?   @db.VarChar(255)
  form2ResultsPdfSize     Int?
  form2ResultsDescription String?   @db.Text
  form2ResultsYear        Int?
  form2ResultsTerm        String?   @db.VarChar(50)
  form2ResultsUploadDate  DateTime?

  // Form 3 Results PDF
  form3ResultsPdf         String?   @db.Text
  form3ResultsPdfName     String?   @db.VarChar(255)
  form3ResultsPdfSize     Int?
  form3ResultsDescription String?   @db.Text
  form3ResultsYear        Int?
  form3ResultsTerm        String?   @db.VarChar(50)
  form3ResultsUploadDate  DateTime?

  // Form 4 Results PDF
  form4ResultsPdf         String?   @db.Text
  form4ResultsPdfName     String?   @db.VarChar(255)
  form4ResultsPdfSize     Int?
  form4ResultsDescription String?   @db.Text
  form4ResultsYear        Int?
  form4ResultsTerm        String?   @db.VarChar(50)
  form4ResultsUploadDate  DateTime?

  // Mock Exams PDF
  mockExamsResultsPdf  String?   @db.Text
  mockExamsPdfName     String?   @db.VarChar(255)
  mockExamsPdfSize     Int?
  mockExamsDescription String?   @db.Text
  mockExamsYear        Int?
  mockExamsTerm        String?   @db.VarChar(50)
  mockExamsUploadDate  DateTime?

  // KCSE Results PDF
  kcseResultsPdf  String?   @db.Text
  kcsePdfName     String?   @db.VarChar(255)
  kcsePdfSize     Int?
  kcseDescription String?   @db.Text
  kcseYear        Int?
  kcseTerm        String?   @db.VarChar(50)
  kcseUploadDate  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Add indexes for new term fields
  @@index([curriculumTerm])
  @@index([feesDayTerm])
  @@index([feesBoardingTerm])
  @@index([admissionFeeTerm])
  @@index([curriculumYear])
  @@index([feesDayYear])
  @@index([feesBoardingYear])
  @@index([admissionFeeYear])
  @@index([form1ResultsYear])
  @@index([form2ResultsYear])
  @@index([form3ResultsYear])
  @@index([form4ResultsYear])
  @@index([mockExamsYear])
  @@index([kcseYear])
  @@map("SchoolDocument")
}

