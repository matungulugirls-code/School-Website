}

model StudentSession {
  id              String   @id @default(cuid())
  studentId       String
  admissionNumber String
  name            String
  token           String   @db.Text
  expiresAt       DateTime
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime @default(now())

  @@index([studentId])
  @@index([token(length: 191)]) // ✅ Prefix index for MySQL TEXT
  @@index([expiresAt])
}

